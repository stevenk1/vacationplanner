# ── Holiday Idea Planner — environment ─────────────────────────────────────
# Copy this file to ".env" and fill in the values, then run: docker compose up --build

# Mapbox PUBLIC access token (required for the map, location search & driving times).
# Create one for free at https://account.mapbox.com/access-tokens/
MAPBOX_TOKEN=pk.your_public_token_here

# PocketBase admin account — used to log into the dashboard at http://localhost:8090/_/
PB_ADMIN_EMAIL=admin@example.com
PB_ADMIN_PASSWORD=change-me-please

# Host ports
WEB_PORT=8080
PB_PORT=8090
