# ── Holiday Idea Planner — environment ─────────────────────────────────────
# Copy this file to ".env" and fill in the values, then run: docker compose up --build

# Mapbox PUBLIC access token (required for the map, location search & driving times).
# Create one for free at https://account.mapbox.com/access-tokens/
MAPBOX_TOKEN=pk.your_public_token_here

# Google Places API key — used SERVER-SIDE ONLY (in the PocketBase hook) to fetch a real
# photo of each place you add. Optional: leave blank to disable photos.
# Setup: Google Cloud Console → enable "Places API (New)" → create an API key → enable billing
# (there is a free monthly tier). The key is never exposed to the browser.
GOOGLE_PLACES_API_KEY=

# Apify API token — used SERVER-SIDE ONLY (in the PocketBase hook) to import a stay from an
# Airbnb listing URL: it auto-fills the stay name/address/coordinates, nightly price & rating,
# and fetches listing photos via the "tri_angle/airbnb-rooms-urls-scraper" actor.
# Optional: leave blank to disable Airbnb import. Get a token at https://console.apify.com/account/integrations
# The token is never exposed to the browser.
APIFY_TOKEN=

# ── PocketBase file storage ────────────────────────────────────────────────
# PocketBase stores the place photos itself — see https://pocketbase.io/docs/files-handling/.
# By DEFAULT files live on the local pb_data volume; this works out of the box with both
# `aspire run` and `docker compose up`, no extra setup. Leave S3_ENABLED=false for this.
#
# Optionally, switch on PocketBase's built-in "Files storage" S3 mode to offload the same
# files to an S3-compatible bucket. PocketBase is an S3 *client*, so this needs an external
# endpoint — AWS S3, Cloudflare R2, MinIO, etc. Set S3_ENABLED=true and fill in the rest:
S3_ENABLED=false
S3_BUCKET=pocketbase
S3_REGION=us-east-1
S3_ENDPOINT=                 # e.g. https://<accountid>.r2.cloudflarestorage.com (blank = AWS S3)
S3_ACCESS_KEY=
S3_SECRET=
S3_FORCE_PATH_STYLE=false    # true for R2 / MinIO, false for AWS S3

# PocketBase admin account — used to log into the dashboard at http://localhost:8090/_/
PB_ADMIN_EMAIL=admin@example.com
PB_ADMIN_PASSWORD=change-me-please

# Host ports
WEB_PORT=31415
PB_PORT=8090
